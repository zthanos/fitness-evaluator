# Fitness Evaluator - Environment Configuration
# Copy this file to .env and fill in your values
# Start the stack first: .\docker-run.ps1 -Command up

# ============================================
# Database (PostgreSQL via docker-compose)
# ============================================
DATABASE_URL=postgresql://fitness_user:fitness_password@localhost:5460/fitness

# ============================================
# Keycloak (identity & access management)
# ============================================
KEYCLOAK_URL=http://localhost:8081
KEYCLOAK_REALM=fitness
KEYCLOAK_CLIENT_ID=fitness-app

# ============================================
# LLM — Ollama (via docker-compose)
# ============================================
LLM_TYPE=ollama
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=mistral

# Embedding model (used by RAG / pgvector)
EMBEDDING_MODEL=nomic-embed-text

# ============================================
# Strava OAuth
# ============================================
# Get credentials at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_strava_client_id_here
STRAVA_CLIENT_SECRET=your_strava_client_secret_here
STRAVA_REDIRECT_URI=http://localhost:8000/api/auth/strava/callback
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
STRAVA_ENCRYPTION_KEY=

# ============================================
# Web Search (Optional)
# ============================================
# Free key at https://tavily.com — enables LLM web search
TAVILY_API_KEY=

# ============================================
# App
# ============================================
ENVIRONMENT=development
LOG_LEVEL=info
SECRET_KEY=dev-secret-key-change-in-production
