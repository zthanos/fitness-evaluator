# Fitness Evaluator - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=sqlite:///./data/fitness_eval.db

# ============================================
# LLM Configuration (Ollama via Docker)
# ============================================
# Ollama service endpoint (Docker Compose)
LM_STUDIO_ENDPOINT=http://ollama:11434/api
# Available models: mistral, neural-chat, dolphin-phi, etc.
LM_STUDIO_MODEL=mistral
# Use 'ollama' for Docker Compose, 'lm-studio' for local LM Studio
LLM_TYPE=ollama

# OR for Local LM Studio (if not using Docker)
# LM_STUDIO_ENDPOINT=http://localhost:1234/v1
# LM_STUDIO_MODEL=local-model
# LLM_TYPE=lm-studio

# ============================================
# Strava OAuth Configuration
# ============================================
# Get these from https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_strava_client_id_here
STRAVA_CLIENT_SECRET=your_strava_client_secret_here
STRAVA_REDIRECT_URI=http://localhost:8000/api/auth/strava/callback

# ============================================
# Web Search Configuration (Optional)
# ============================================
# Get a free API key at https://tavily.com
# Enables the LLM to search the web for current fitness information
TAVILY_API_KEY=your_tavily_api_key_here

# ============================================
# API Configuration
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_WORKERS=1

# ============================================
# Logging
# ============================================
LOG_LEVEL=info

# ============================================
# Environment
# ============================================
ENVIRONMENT=development
# Set to 'production' for production deployments
