{
  "realm": "fitness",
  "displayName": "Fitness App",
  "displayNameHtml": "<b>Fitness App</b>",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "registrationEmailAsUsername": false,
  "rememberMe": true,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "accessTokenLifespan": 300,
  "accessTokenLifespanForImplicitFlow": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionIdleTimeout": 2592000,
  "defaultSignatureAlgorithm": "RS256",
  "roles": {
    "realm": [
      {
        "name": "athlete",
        "description": "Standard fitness app user"
      },
      {
        "name": "admin",
        "description": "Platform administrator"
      }
    ]
  },
  "defaultRoles": ["athlete"],
  "clients": [
    {
      "clientId": "fitness-app",
      "name": "Fitness App (SPA)",
      "description": "Public client for the Fitness SPA frontend",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:8000/*",
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "http://localhost:8000",
        "http://localhost:3000"
      ],
      "notBefore": 0,
      "bearerOnly": false,
      "consentRequired": false,
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "web-origins",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ],
      "protocolMappers": [
        {
          "name": "athlete-id-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "athlete_id",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "athlete_id",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "fitness-api",
      "name": "Fitness API (Backend)",
      "description": "Confidential client for backend-to-backend auth and token introspection",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "fitness-api-secret-changeme",
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "bearerOnly": false,
      "consentRequired": false,
      "fullScopeAllowed": false
    }
  ],
  "users": [
    {
      "username": "athlete",
      "email": "athlete@fitness.local",
      "firstName": "Default",
      "lastName": "Athlete",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "changeme",
          "temporary": false
        }
      ],
      "realmRoles": ["athlete"],
      "attributes": {}
    },
    {
      "username": "admin",
      "email": "admin@fitness.local",
      "firstName": "Platform",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin_changeme",
          "temporary": false
        }
      ],
      "realmRoles": ["athlete", "admin"],
      "attributes": {}
    }
  ],
  "browserSecurityHeaders": {
    "contentSecurityPolicyReportOnly": "",
    "xContentTypeOptions": "nosniff",
    "xRobotsTag": "none",
    "xFrameOptions": "SAMEORIGIN",
    "contentSecurityPolicy": "frame-src 'self'; frame-ancestors 'self'; object-src 'none';",
    "xXSSProtection": "1; mode=block",
    "strictTransportSecurity": "max-age=31536000; includeSubDomains"
  },
  "smtpServer": {},
  "eventsEnabled": false,
  "adminEventsEnabled": false,
  "internationalizationEnabled": false,
  "supportedLocales": ["en"],
  "defaultLocale": "en"
}
