"# Strava OAuth2
STRAVA_CLIENT_ID=your_client_id_here
STRAVA_CLIENT_SECRET=your_client_secret_here
STRAVA_REDIRECT_URI=http://localhost:8000/auth/strava/callback

# LLM Configuration (OpenAI-compatible endpoints)
# IMPORTANT: Use base URL only (host:port), WITHOUT /api or /v1 suffixes
# The system automatically appends /v1/chat/completions to construct the full endpoint

# Ollama Configuration
# Docker example: http://ollama:11434
# Local example: http://localhost:11434
OLLAMA_ENDPOINT=http://ollama:11434
OLLAMA_MODEL=mistral
LLM_TYPE=ollama

# LM Studio Configuration (for local development)
# Example: http://localhost:1234
# The system will construct: http://localhost:1234/v1/chat/completions
LM_STUDIO_BASE_URL=http://localhost:1234
LM_STUDIO_MODEL=deepseek-r1-distill-qwen-7b

# App
DATABASE_URL=sqlite:///./fitness.db
SECRET_KEY=change_me_to_a_random_256bit_secret

# Chat Runtime Feature Flags (Phase 6)
# Set to true to enable the new Context Engineering chat runtime
USE_CE_CHAT_RUNTIME=false
# Set to false to disable the legacy chat path (only after CE is stable)
LEGACY_CHAT_ENABLED=true
# Token budget for CE context builder
CE_CHAT_TOKEN_BUDGET=2400
# Max tool orchestration iterations
CE_CHAT_MAX_TOOL_ITERATIONS=5"